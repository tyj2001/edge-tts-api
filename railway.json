{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "PACKAGE",
    "pythonVersion": "3.11"
  },
  "deploy": {
    "numReplicas": 1,
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "startCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT"
  }
}
